<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_voice_instruction_list" model="ir.ui.view">
        <field name="name">voice.instruction.list</field>
        <field name="model">voice.instruction</field>
        <field name="arch" type="xml">
            <list string="Registros de voz" default_order="create_date desc">
                <field name="create_date" string="Fecha"/>
                <field name="user_id"/>
                <field name="name"/>
                <field name="duration"/>
                <field name="audio_filename"/>
            </list>
        </field>
    </record>

    <record id="view_voice_instruction_form" model="ir.ui.view">
        <field name="name">voice.instruction.form</field>
        <field name="model">voice.instruction</field>
        <field name="arch" type="xml">
            <form string="Registro de voz">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <field name="user_id"/>
                        <field name="create_date" string="Fecha"/>
                        <field name="duration"/>
                        <field name="audio_mimetype"/>
                        <field name="audio_filename" invisible="1"/>
                    </group>
                    <group string="Audio">
                        <field name="audio_player" widget="html" nolabel="1"
                               colspan="2" readonly="1"/>
                        <field name="audio_attachment_id" invisible="1"/>
                    </group>
                    <group string="Transcripción">
                        <field name="transcript" colspan="2" nolabel="1" placeholder="Texto reconocido..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_voice_instruction" model="ir.actions.act_window">
        <field name="name">Registros de voz</field>
        <field name="res_model">voice.instruction</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_voice_root" name="Voz a texto" sequence="90"/>
    <menuitem id="menu_voice_instruction" name="Registros de voz"
              parent="menu_voice_root" action="action_voice_instruction" sequence="10"/>

    <function model="voice.instruction" name="_ensure_chatter_audio_attachments"/>
</odoo>
